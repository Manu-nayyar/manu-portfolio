{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/style.css",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/script.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/projects/smart-food-safe", "destination": "/projects/smart-food-safe.html" },
    { "source": "/projects/free-india-plastic", "destination": "/projects/free-india-plastic.html" },
    { "source": "/projects/realtor-maneesh", "destination": "/projects/realtor-maneesh.html" },
    { "source": "/projects/directory-for-ai", "destination": "/projects/directory-for-ai.html" }
  ]
}
